{
	"name": "df_clean_superstore_sales",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_superstore_source",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_superstore_processed",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filtersales"
				},
				{
					"name": "filterNull"
				},
				{
					"name": "drvBusinessMetrics"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Row ID} as string,",
				"          {Order ID} as string,",
				"          {Order Date} as string,",
				"          {Ship Date} as string,",
				"          {Ship Mode} as string,",
				"          {Customer ID} as string,",
				"          {Customer Name} as string,",
				"          Segment as string,",
				"          Country as string,",
				"          City as string,",
				"          State as string,",
				"          {Postal Code} as string,",
				"          Region as string,",
				"          {Product ID} as string,",
				"          Category as string,",
				"          {Sub-Category} as string,",
				"          {Product Name} as string,",
				"          Sales as string,",
				"          Quantity as string,",
				"          Discount as string,",
				"          Profit as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 filter(toInteger(Sales) > 0) ~> filtersales",
				"filtersales filter(!isNull({Customer Name})) ~> filterNull",
				"filterNull derive({Profit Margin} = round((toDecimal(Profit)/toDecimal(Sales))*100, 1),",
				"          {Discount Category} = iif(toDecimal(Discount)==0,'No Discount',     iif(toDecimal(Discount)<=0.2,'Low Discount',         'High Discount')),",
				"          {Revenue per Unit} = round(toDecimal(Sales)/toInteger(Quantity),2),",
				"          Discount = round(toDecimal(Discount) * 100, 0),",
				"          {Profit per Unit} = round(toDecimal(Profit)/toInteger(Quantity),2)) ~> drvBusinessMetrics",
				"drvBusinessMetrics sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['superstore_sales_transformed.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          {Row ID},",
				"          {Order ID},",
				"          {Order Date},",
				"          {Ship Date},",
				"          {Ship Mode},",
				"          {Customer ID},",
				"          {Customer Name},",
				"          Segment,",
				"          Country,",
				"          City,",
				"          State,",
				"          {Postal Code},",
				"          Region,",
				"          {Product ID},",
				"          Category,",
				"          {Sub-Category},",
				"          {Product Name},",
				"          Sales,",
				"          Quantity,",
				"          {Discount(%)} = Discount,",
				"          Profit,",
				"          {Profit Margin},",
				"          {Discount Category},",
				"          {Revenue per Unit},",
				"          {Profit per Unit}",
				"     ),",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}